// Resource overrides for Cirro / AWS Batch runs.
// Mirrors nextflow/conf/base.config — duplicated here because Cirro
// loads this file from S3 via `-c`, and `includeConfig "${baseDir}/..."`
// did not resolve in that context (every process fell back to Nextflow's
// ~1-2 GB default, causing OOM on DOWNLOAD_REFERENCE / bwa index).

process {
    errorStrategy = { task.exitStatus == 104 || (task.exitStatus >= 137 && task.exitStatus <= 143) ? 'retry' : 'finish' }
    maxRetries    = 2

    withName: 'DOWNLOAD_HG38' {
        cpus   = 1
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withName: 'DOWNLOAD_REFERENCE' {
        cpus   = 1
        memory = { 16.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withName: 'DOWNLOAD_HOST_INDEX' {
        cpus   = 1
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withName: 'DOWNLOAD_KRAKEN_DB' {
        cpus   = 1
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withName: 'PREFILTER' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
        time   = { 8.h  * task.attempt }
    }
    withName: 'QCFILTER' {
        cpus   = 16
        memory = { 64.GB * task.attempt }
        time   = { 1.h   * task.attempt }
    }
    withName: 'T2TFILTER' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
        time   = { 1.h  * task.attempt }
    }
    withName: 'CLASSIFY_KRAKEN' {
        cpus   = 32
        memory = { 128.GB * task.attempt }
        time   = { 1.h    * task.attempt }
    }
    withName: 'SUMMARIZE' {
        cpus   = 1
        memory = { 4.GB * task.attempt }
        time   = { 1.h  * task.attempt }
    }
    withName: 'CRAM_TO_BAM' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
}
