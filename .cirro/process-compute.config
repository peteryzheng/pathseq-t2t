// Cirro / AWS Batch overlay. All per-process resource directives and
// the retry-scaling errorStrategy come from nextflow/conf/base.config,
// which is loaded at the top of nextflow/nextflow.config so it applies
// regardless of -profile.
//
// Cirro-specific tweaks (e.g. AWS Batch container options, larger
// maxRetries) belong inside profiles.standard.

profiles {
    standard {
        process {
            // (no overrides — base.config defaults are sufficient for v1)
        }
    }
}
