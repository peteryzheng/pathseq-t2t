nextflow.enable.dsl = 2

plugins {
    id 'nf-schema@2.1.1'
}

// ── Default params ────────────────────────────────────────────────────────────
params {
    // Required
    samplesheet     = null
    hostdir         = null   // path to PathSeq host dir (pathseq_host.bfi + .fa.img)
    reference       = null   // path to T2T FASTA

    // Optional pipeline behaviour
    outdir          = './results'
    aligner         = 'bwa'  // 'bwa' or 'dragen'
    decoys_bed      = "${projectDir.parent}/non_human_decoys.bed"
    classifiers     = 'kraken'  // comma-separated: kraken, metaphlan, sylph
    assembly        = false
    help            = false

    // Resource limits (used by check_max() in base.config)
    max_cpus        = 16
    max_memory      = '128.GB'
    max_time        = '240.h'

    // Classifier indices (optional — auto-downloaded if null)
    // Kraken2 pre-built DB tarball URL; override to use a larger DB:
    //   https://benlangmead.github.io/aws-indexes/k2
    kraken_db_url   = 'https://genome-idx.s3.amazonaws.com/kraken/k2_standard_08gb_20240605.tar.gz'
    kraken_index    = null
    metaphlan_index = 'mpa_vJun23_CHOCOPhlAnSGB_202403'  // index name; auto-downloaded if bowtie2_index is null
    bowtie2_index   = null   // dir containing MetaPhlAn bowtie2 index; auto-downloaded if null
    sylph_db_url    = null   // URL to .syldb file; used when sylph_index is null
    sylph_index     = null   // path to pre-staged .syldb file; takes priority over sylph_db_url
    sylph_taxonomy  = null   // sylph taxonomy tag (see classify --help); required when using sylph

    // Assembly optional extras
    checkv_db       = null   // path to CheckV database (required for binqc --model checkv|both)
    gtdbtk_data     = null   // GTDBTK_DATA_PATH (required for binclassify)

    // AWS Batch (required when using -profile aws)
    aws_queue       = null
    aws_region      = 'us-east-1'
    s3_work_dir     = null

    // SLURM (used with -profile slurm)
    slurm_queue       = null   // SLURM partition, e.g. 'short', 'normal', 'bigmem'
    slurm_account     = null   // SLURM account / project, e.g. 'beroukhim_lab'
    slurm_options     = null   // extra #SBATCH flags, e.g. '--constraint=cascade'

    // CRAM inputs (optional)
    hg38_ref          = null   // GATK.GRCh38 FASTA for CRAM decoding; auto-downloaded if null
}

process.container = 'ghcr.io/peteryzheng/pathseq-t2t:main'

// Per-process CPU / memory / time / retry directives.
// Loaded at top level (not inside profiles) so they apply in every
// runtime context — local, slurm, aws, and Cirro (which runs without
// a -profile). Matches the canonical nf-core layout.
includeConfig 'conf/base.config'

// Per-module behavior overrides (publishDir, ext.args, ext.prefix).
// Kept separate from base.config so output paths can be tweaked
// without editing module .nf files. Matches nf-core convention.
includeConfig 'conf/modules.config'

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    local {
        process.executor  = 'local'
        docker.enabled    = true
    }

    aws {
        includeConfig 'conf/aws.config'
    }

    slurm {
        includeConfig 'conf/slurm.config'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// ── Validation ────────────────────────────────────────────────────────────────
validation {
    help {
        enabled = true
    }
    ignoreParams = ['config_profile_name', 'config_profile_description']
}

// ── Reporting ─────────────────────────────────────────────────────────────────
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_report.html"
}
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_timeline.html"
}
dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_dag.html"
}
