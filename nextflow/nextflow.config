nextflow.enable.dsl = 2

// ── Default params ────────────────────────────────────────────────────────────
params {
    // Required
    samplesheet     = null
    hostdir         = null   // path to PathSeq host dir (pathseq_host.bfi + .fa.img)
    reference       = null   // path to T2T FASTA

    // Optional pipeline behaviour
    outdir          = './results'
    aligner         = 'bwa'  // 'bwa' or 'dragen'
    decoys_bed      = "${projectDir}/../non_human_decoys.bed"
    classifiers     = 'kraken'  // comma-separated: kraken, metaphlan, sylph
    assembly        = false

    // Classifier indices (optional — auto-downloaded if null)
    // Kraken2 pre-built DB tarball URL; override to use a larger DB:
    //   https://benlangmead.github.io/aws-indexes/k2
    kraken_db_url   = 'https://genome-idx.s3.amazonaws.com/kraken/k2_standard_08gb_20240605.tar.gz'
    kraken_index    = null
    metaphlan_index = null   // index name, e.g. mpa_vJun23_CHOCOPhlAnSGB_202403
    bowtie2_index   = null   // dir containing MetaPhlAn bowtie2 index
    sylph_index     = null   // path to .syldb file
    sylph_taxonomy  = null   // sylph taxonomy tag (see classify --help)

    // Assembly optional extras
    checkv_db       = null   // path to CheckV database (required for binqc --model checkv|both)
    gtdbtk_data     = null   // GTDBTK_DATA_PATH (required for binclassify)

    // AWS Batch (required when using -profile aws)
    docker_image    = null
    aws_queue       = null
    aws_region      = 'us-east-1'
    s3_work_dir     = null

    // SLURM (used with -profile slurm)
    slurm_queue       = null   // SLURM partition, e.g. 'short', 'normal', 'bigmem'
    slurm_account     = null   // SLURM account / project, e.g. 'beroukhim_lab'
    slurm_options     = null   // extra #SBATCH flags, e.g. '--constraint=cascade'
    singularity_image = null   // local .sif path or docker:// URI

    // CRAM inputs (optional)
    hg38_ref          = null   // hg38 FASTA for CRAM decoding; auto-downloaded from UCSC if null
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    local {
        process.executor  = 'local'
        process.container = params.docker_image
        docker.enabled    = true
        includeConfig 'conf/resources.config'
    }

    aws {
        includeConfig 'conf/resources.config'
        includeConfig 'conf/aws.config'
    }

    slurm {
        process.container = params.singularity_image
        includeConfig 'conf/resources.config'
        includeConfig 'conf/slurm.config'
    }

    test {
        // Minimal resources for local stub / dry-run validation — no real tools needed.
        conda.enabled = false
        process {
            cpus   = 1
            memory = '2 GB'
            time   = '10m'
        }
    }
}

// ── Reporting ─────────────────────────────────────────────────────────────────
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_dag.html"
}
