// Minimal resources for local stub / dry-run validation — no real tools needed.
params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test run — stub mode, no real tools needed'

    max_cpus   = 2
    max_memory = '4.GB'
    max_time   = '6.h'
}

process {
    cpus   = 1
    memory = '2 GB'
    time   = '10m'
    conda.enabled = false
}
