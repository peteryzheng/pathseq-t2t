// SLURM + Singularity configuration.
// Modeled after DFCI ERISTwo (Partners Healthcare) cluster setup.
// Adjust beforeScript, resourceLimits, and queue logic for your cluster.

process {
    executor  = 'slurm'
    queue     = params.slurm_queue

    clusterOptions = [
        params.slurm_account ? "--account=${params.slurm_account}" : "",
        params.slurm_options ?: ""
    ].findAll { it }.join(" ") ?: null

    // Load Singularity before each task — update the module name for your cluster.
    beforeScript = '''
        module load singularity/3.7.0
        set +o noclobber
    '''

    resourceLimits = [
        cpus:   80,
        memory: '1024.GB',
        time:   '384.h'
    ]
}

singularity {
    enabled    = true
    autoMounts = true
}

executor {
    name                = 'slurm'
    queueSize           = 500
    submitRateLimit     = '10 sec'
    perCpuMemAllocation = true
    pollInterval        = '2s'
    retry.delay         = '5s'
}

// Cache pulled Singularity images so they are reused across runs.
env {
    NXF_SINGULARITY_CACHEDIR = "${params.outdir}/_singularity_cache"
    SINGULARITY_CACHEDIR     = "${params.outdir}/_singularity_cache"
    APPTAINER_CACHEDIR       = "${params.outdir}/_singularity_cache"
}
