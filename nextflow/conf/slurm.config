// SLURM executor configuration.
// Set partition/account via --slurm_queue / --slurm_account on the CLI,
// or override the defaults below directly for your cluster.

process {
    executor = 'slurm'
    queue    = params.slurm_queue

    // Build clusterOptions from optional account + extra flags.
    clusterOptions = [
        params.slurm_account ? "--account=${params.slurm_account}" : "",
        params.slurm_options ?: ""
    ].findAll { it }.join(" ") ?: null
}

// Nextflow activates the conda env on each compute node before running the task.
conda.enabled = true
