// nf-core check_max() helper — caps requested resources at params.max_* limits.
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            return obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1
                ? params.max_memory as nextflow.util.MemoryUnit : obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            return obj.compareTo(params.max_time as nextflow.util.Duration) == 1
                ? params.max_time as nextflow.util.Duration : obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj as int, params.max_cpus as int)
        } catch (all) { return obj }
    }
}

def retry_scale(attempt) {
    try {
        return Math.pow(2, (attempt as int) - 1) as int
    } catch (all) {
        return 1
    }
}

process {
    errorStrategy = { task.exitStatus == 104 || (task.exitStatus >= 137 && task.exitStatus <= 143) ? 'retry' : 'terminate' }
    maxRetries = 2

    withName: 'PREFILTER' {
        cpus   = { check_max(4,       'cpus')   }
        memory = { check_max(8.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(8.h  * retry_scale(task.attempt), 'time')   }
    }
    withName: 'QCFILTER' {
        cpus   = { check_max(16,      'cpus')   }
        memory = { check_max(64.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(1.h   * retry_scale(task.attempt), 'time')   }
    }
    withName: 'T2TFILTER' {
        cpus   = { check_max(4,       'cpus')   }
        memory = { check_max(8.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(1.h  * retry_scale(task.attempt), 'time')   }
    }
    withName: 'CLASSIFY_KRAKEN' {
        cpus   = { check_max(32,      'cpus')   }
        memory = { check_max(128.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(30.m   * retry_scale(task.attempt), 'time')   }
    }
    withName: 'CLASSIFY_METAPHLAN' {
        cpus   = { check_max(16,      'cpus')   }
        memory = { check_max(64.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(3.h   * retry_scale(task.attempt), 'time')   }
    }
    withName: 'CLASSIFY_SYLPH' {
        cpus   = { check_max(4,       'cpus')   }
        memory = { check_max(16.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(30.m  * retry_scale(task.attempt), 'time')   }
    }
    withName: 'ASSEMBLE' {
        cpus   = { check_max(8,       'cpus')   }
        memory = { check_max(32.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(10.h  * retry_scale(task.attempt), 'time')   }
    }
    withName: 'BINQC' {
        cpus   = { check_max(4,       'cpus')   }
        memory = { check_max(8.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(1.h  * retry_scale(task.attempt), 'time')   }
    }
    withName: 'BINCLASSIFY' {
        cpus   = { check_max(8,       'cpus')   }
        memory = { check_max(32.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(2.h   * retry_scale(task.attempt), 'time')   }
    }
    withName: 'SUMMARIZE' {
        cpus   = { check_max(1,       'cpus')   }
        memory = { check_max(4.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(30.m * retry_scale(task.attempt), 'time')   }
    }
    withName: 'SUMMARIZE_ASSEMBLY' {
        cpus   = { check_max(1,       'cpus')   }
        memory = { check_max(4.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(30.m * retry_scale(task.attempt), 'time')   }
    }
    withName: 'CRAM_TO_BAM' {
        cpus   = { check_max(4,       'cpus')   }
        memory = { check_max(8.GB * retry_scale(task.attempt), 'memory') }
        time   = { check_max(2.h  * retry_scale(task.attempt), 'time')   }
    }
}
