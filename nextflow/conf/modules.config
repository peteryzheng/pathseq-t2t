/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-module behavior overrides (publishDir, ext.args, etc.).
    Resource directives (cpus/memory/time/retry) live in conf/base.config.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    withName: 'T2TFILTER|CLASSIFY_KRAKEN|CLASSIFY_METAPHLAN|CLASSIFY_SYLPH|ASSEMBLE|BINQC|BINCLASSIFY' {
        publishDir = [ path: { "${params.outdir}/${meta.id}" }, mode: 'copy' ]
    }
    withName: 'SUMMARIZE|SUMMARIZE_ASSEMBLY' {
        publishDir = [ path: { "${params.outdir}/${meta.id}/results" }, mode: 'copy' ]
    }
}
