// AWS Batch executor configuration.
// Required params (set in nextflow.config or on the command line):
//   --aws_queue      ARN or name of your AWS Batch job queue
//   --aws_region     AWS region (default: us-east-1)
//   --s3_work_dir    s3://your-bucket/work  (Nextflow work directory)

aws {
    region = params.aws_region
    batch {
        cliPath    = '/usr/local/bin/aws'
        // Increase if jobs are large and need more time to spin up
        maxTransferAttempts = 3
    }
}

process {
    executor  = 'awsbatch'
    queue     = params.aws_queue

    // EFS/FSx mount point for reference data and large outputs.
    // Set this to wherever your EFS is mounted inside the container.
    // containerOptions = '--volume /mnt/efs:/mnt/efs'
}

workDir = params.s3_work_dir
